{
  "name": "@gigachad-grc/policies",
  "version": "1.0.0",
  "description": "Policy Center Service",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "prisma:generate": "cp ../shared/prisma/schema.prisma ./.prisma.schema.prisma && PRISMA_GENERATE_SKIP_AUTOINSTALL=1 ./node_modules/.bin/prisma generate --schema=./.prisma.schema.prisma && rm ./.prisma.schema.prisma",
    "prisma:migrate": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 ./node_modules/.bin/prisma migrate dev --schema=../shared/prisma/schema.prisma",
    "prisma:push": "PRISMA_GENERATE_SKIP_AUTOINSTALL=1 ./node_modules/.bin/prisma db push --schema=../shared/prisma/schema.prisma"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.2.0",
    "@prisma/client": "^5.8.0",
    "@gigachad-grc/shared": "file:../shared",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "prisma": "^5.8.0",
    "typescript": "^5.3.3"
  }
}

