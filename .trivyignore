CVE-2026-26278  # high - file-type: overrides force 21.3.2 (PR #212, #172)
CVE-2026-26996  # high - file-type: overrides force 21.3.2 (PR #212, #172)
CVE-2026-27903  # high - npm overrides updated in PR #172; stale container
CVE-2026-27904  # high - npm overrides updated in PR #172; stale container
CVE-2026-27942  # low - npm overrides updated in PR #172; stale container
CVE-2025-69873  # medium - npm overrides force patched; container rebuild required
GHSA-6475-r3vj-m8vf  # low - @smithy/config-resolver: defense-in-depth, already updated in main

