# ==============================================================================
# GigaChad GRC - Production Environment Configuration
# ==============================================================================
#
# IMPORTANT:
# 1. Copy this file to .env.prod
# 2. Replace ALL placeholder values with strong, unique values
# 3. NEVER commit .env.prod to version control
# 4. Store secrets in a secure vault (e.g., AWS Secrets Manager, HashiCorp Vault)
# 5. Rotate secrets regularly (at least every 90 days)
#
# ==============================================================================

# ==============================================================================
# APPLICATION SETTINGS
# ==============================================================================
NODE_ENV=production
APP_DOMAIN=grc.example.com
IMAGE_TAG=latest

# ==============================================================================
# SSL/TLS CONFIGURATION
# ==============================================================================
# Let's Encrypt email for certificate notifications
ACME_EMAIL=admin@example.com

# ==============================================================================
# DATABASE CONFIGURATION - PostgreSQL
# ==============================================================================
# SECURITY: Use strong passwords (min 32 chars, alphanumeric + special chars)
POSTGRES_USER=grc_prod_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD_MIN_32_CHARS_Abc123!@#$%
POSTGRES_DB=gigachad_grc_prod

# Connection pool settings
POSTGRES_MAX_CONNECTIONS=100
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB

# ==============================================================================
# REDIS CONFIGURATION
# ==============================================================================
# SECURITY: Use strong passwords (min 32 chars)
REDIS_PASSWORD=REPLACE_WITH_STRONG_REDIS_PASSWORD_MIN_32_CHARS_Xyz789!@#$%
REDIS_MAX_MEMORY=512mb
REDIS_LOG_LEVEL=warning

# ==============================================================================
# KEYCLOAK CONFIGURATION
# ==============================================================================
# SECURITY: Change default admin credentials immediately
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=REPLACE_WITH_STRONG_KEYCLOAK_PASSWORD_MIN_32_CHARS_Def456!@#

# Keycloak hostname (should match your domain)
KEYCLOAK_HOSTNAME=auth.grc.example.com
KEYCLOAK_REALM=grc

# Database connection pool
KC_DB_POOL_INITIAL_SIZE=5
KC_DB_POOL_MIN_SIZE=5
KC_DB_POOL_MAX_SIZE=20

# Logging
KC_LOG_LEVEL=info

# ==============================================================================
# MINIO/S3 OBJECT STORAGE CONFIGURATION
# ==============================================================================
# SECURITY: Use strong credentials (min 20 chars for password)
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_MINIO_PASSWORD_MIN_20_CHARS_Ghi789!@#
MINIO_BROWSER=on
MINIO_DOMAIN=storage.grc.example.com

# S3-compatible storage settings
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=grc-evidence-prod

# If using AWS S3 instead of MinIO, configure:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=grc-evidence-prod

# ==============================================================================
# JWT & SESSION SECRETS
# ==============================================================================
# SECURITY: Generate using: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_RANDOM_JWT_SECRET_MIN_64_CHARS_USE_openssl_rand_base64_64
SESSION_SECRET=REPLACE_WITH_RANDOM_SESSION_SECRET_MIN_64_CHARS_USE_openssl_rand_base64_64
ENCRYPTION_KEY=REPLACE_WITH_RANDOM_ENCRYPTION_KEY_32_CHARS_USE_openssl_rand_hex_32

# JWT expiration times
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# ==============================================================================
# EMAIL/SMTP CONFIGURATION
# ==============================================================================
# Email service for notifications and alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=noreply@example.com
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM=GigaChad GRC <noreply@example.com>

# Email templates
EMAIL_TEMPLATE_DIR=/app/templates/email

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Application-specific log levels
TRAEFIK_LOG_LEVEL=WARN
KC_LOG_LEVEL=info
REDIS_LOG_LEVEL=warning

# ==============================================================================
# SECURITY SETTINGS
# ==============================================================================
# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# CORS settings
CORS_ORIGIN=https://grc.example.com
CORS_CREDENTIALS=true

# Security headers
HSTS_MAX_AGE=31536000
CSP_ENABLED=true

# Session settings
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=strict
SESSION_MAX_AGE=86400000

# ==============================================================================
# BACKUP CONFIGURATION
# ==============================================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=grc-backups-prod
BACKUP_ENCRYPTION_KEY=REPLACE_WITH_BACKUP_ENCRYPTION_KEY_USE_openssl_rand_hex_32

# ==============================================================================
# MONITORING & OBSERVABILITY
# ==============================================================================
# Metrics
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# APM (Application Performance Monitoring)
APM_ENABLED=false
APM_SERVICE_NAME=gigachad-grc
APM_SERVER_URL=

# Sentry error tracking
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# ==============================================================================
# FEATURE FLAGS
# ==============================================================================
FEATURE_AI_ASSISTANT=true
FEATURE_ADVANCED_ANALYTICS=true
FEATURE_API_V2=false
FEATURE_AUDIT_TRAIL=true
FEATURE_TWO_FACTOR_AUTH=true
FEATURE_SSO=true

# ==============================================================================
# THIRD-PARTY INTEGRATIONS
# ==============================================================================
# Slack notifications
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#grc-alerts

# Microsoft Teams
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=

# Jira integration
JIRA_ENABLED=false
JIRA_URL=
JIRA_USERNAME=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ==============================================================================
# COMPLIANCE & AUDIT SETTINGS
# ==============================================================================
AUDIT_LOG_RETENTION_DAYS=2555
COMPLIANCE_MODE=strict
DATA_RESIDENCY=US
GDPR_ENABLED=true
HIPAA_ENABLED=false
SOC2_MODE=true

# ==============================================================================
# PERFORMANCE TUNING
# ==============================================================================
# Node.js settings
NODE_OPTIONS=--max-old-space-size=2048
UV_THREADPOOL_SIZE=8

# Database query timeout
DB_QUERY_TIMEOUT=30000
DB_STATEMENT_TIMEOUT=60000

# Redis cache TTL (seconds)
CACHE_TTL_SHORT=300
CACHE_TTL_MEDIUM=3600
CACHE_TTL_LONG=86400

# File upload limits
MAX_FILE_SIZE=100MB
MAX_FILES_PER_UPLOAD=10

# ==============================================================================
# MAINTENANCE MODE
# ==============================================================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.
MAINTENANCE_ALLOWED_IPS=

# ==============================================================================
# NOTIFICATION SETTINGS
# ==============================================================================
NOTIFICATIONS_ENABLED=true
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_SLACK_ENABLED=false
NOTIFICATION_WEBHOOK_ENABLED=false

# Notification throttling
NOTIFICATION_RATE_LIMIT=10
NOTIFICATION_RATE_WINDOW=60000

# ==============================================================================
# DATA RETENTION & CLEANUP
# ==============================================================================
# Automatic cleanup settings
CLEANUP_ENABLED=true
CLEANUP_SCHEDULE=0 3 * * 0
CLEANUP_TEMP_FILES_DAYS=7
CLEANUP_DELETED_RECORDS_DAYS=90
CLEANUP_AUDIT_LOGS_DAYS=2555

# ==============================================================================
# TIMEZONE & LOCALIZATION
# ==============================================================================
TZ=UTC
DEFAULT_LOCALE=en-US
SUPPORTED_LOCALES=en-US,en-GB,es-ES,fr-FR,de-DE

# ==============================================================================
# API SETTINGS
# ==============================================================================
API_VERSION=v1
API_RATE_LIMIT=1000
API_RATE_WINDOW=3600000
API_TIMEOUT=30000

# API Documentation
API_DOCS_ENABLED=false
API_DOCS_PATH=/api/docs

# ==============================================================================
# WEBHOOK SETTINGS
# ==============================================================================
WEBHOOK_ENABLED=true
WEBHOOK_TIMEOUT=10000
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=5000

# ==============================================================================
# STORAGE CONFIGURATION
# ==============================================================================
STORAGE_TYPE=minio
LOCAL_STORAGE_PATH=/data/storage

# MinIO/S3 Storage Settings
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}

# ==============================================================================
# HEALTH CHECK CONFIGURATION
# ==============================================================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_PATH=/health
HEALTH_CHECK_INTERVAL=30000

# ==============================================================================
# DATABASE BACKUP CONFIGURATION
# ==============================================================================
# PostgreSQL backup settings
PG_BACKUP_ENABLED=true
PG_BACKUP_COMPRESSION=gzip
PG_BACKUP_FORMAT=custom
PG_BACKUP_JOBS=4

# ==============================================================================
# DISASTER RECOVERY
# ==============================================================================
DR_ENABLED=true
DR_BACKUP_LOCATION=/backups
DR_REMOTE_BACKUP_ENABLED=false
DR_REMOTE_BACKUP_S3_BUCKET=
DR_REMOTE_BACKUP_REGION=

# ==============================================================================
# SECURITY SCANNING
# ==============================================================================
SECURITY_SCAN_ENABLED=false
VULNERABILITY_SCAN_SCHEDULE=0 4 * * 0
SECURITY_ALERTS_EMAIL=security@example.com

# ==============================================================================
# NOTES
# ==============================================================================
# Password Generation Commands:
# - Strong password (32 chars): openssl rand -base64 32
# - JWT Secret (64 chars): openssl rand -base64 64
# - Encryption key (hex): openssl rand -hex 32
#
# Security Checklist:
# [ ] All default passwords changed
# [ ] JWT secrets generated with openssl
# [ ] SMTP credentials configured
# [ ] SSL certificates configured
# [ ] Backup encryption key set
# [ ] Rate limiting enabled
# [ ] CORS origins configured
# [ ] Firewall rules applied
# [ ] Database backups tested
# [ ] Monitoring alerts configured
# [ ] Log aggregation setup
#
# ==============================================================================
