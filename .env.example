# Database Configuration
POSTGRES_USER=grc
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=gigachad_grc

# Redis Configuration
REDIS_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Keycloak Configuration
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION
KEYCLOAK_REALM=grc
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_PORT=8080

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Storage Configuration
STORAGE_TYPE=minio
LOCAL_STORAGE_PATH=./storage

# MinIO/S3 Storage Settings
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=${MINIO_ROOT_USER}
MINIO_SECRET_KEY=${MINIO_ROOT_PASSWORD}
MINIO_BUCKET=grc-evidence

# Application Configuration
NODE_ENV=development

# Email Configuration
# Provider options: console (logs to console), smtp, sendgrid, ses
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@gigachad-grc.com
EMAIL_FROM_NAME=GigaChad GRC
FRONTEND_URL=http://localhost:3000

# SMTP Configuration (if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# SendGrid Configuration (if EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=your-sendgrid-api-key

# AWS SES Configuration (if EMAIL_PROVIDER=ses)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
