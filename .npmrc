# Disable npm lifecycle scripts (preinstall, install, postinstall, prepare,
# etc.) globally as a supply-chain defense. This blocks the most common npm
# attack vector: arbitrary code execution via postinstall hooks at install
# time.
#
# When this file is in effect, `npm ci` and `npm install` will NOT run:
#   - prepare (husky git hook setup)
#   - postinstall (Prisma client generation in each service)
#
# To do those things, invoke them explicitly:
#   npm run db:generate    # generate Prisma client across workspaces
#   npm run prepare        # set up local git hooks (husky)
#   npm run setup          # do both (recommended for new clones)
#
# CI workflows that need the Prisma client run `npm run db:generate`
# explicitly after `npm ci`. See .github/workflows/pr-validation.yml.
ignore-scripts=true

# Verify package provenance via sigstore where attestations are available.
# Currently advisory only; npm audit signatures is run in CI as a separate
# blocking step.
fund=false
